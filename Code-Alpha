<script>
document.addEventListener('DOMContentLoaded', function () {
    const brandColors = {
        primary: '#0052D4',
        secondary: '#4364F7',
        accent: '#6FB1FC',
        light: '#B2C5FF',
        textColor: '#4A5568',
        gridColor: 'rgba(0, 0, 0, 0.1)'
    };

    const wrapLabel = (label, maxWidth = 16) => {
        if (typeof label !== 'string' || label.length <= maxWidth) {
            return label;
        }
        const words = label.split(' ');
        const lines = [];
        let currentLine = '';
        words.forEach(word => {
            if ((currentLine + ' ' + word).trim().length > maxWidth) {
                lines.push(currentLine.trim());
                currentLine = word;
            } else {
                currentLine = (currentLine + ' ' + word).trim();
            }
        });
        if (currentLine) {
            lines.push(currentLine.trim());
        }
        return lines;
    };

    const tooltipTitleCallback = (tooltipItems) => {
        const item = tooltipItems[0];
        let label = item.chart.data.labels[item.dataIndex];
        if (Array.isArray(label)) {
            return label.join(' ');
        }
        return label;
    };
    
    const defaultChartOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                labels: {
                    color: brandColors.textColor,
                    font: {
                        family: "'Inter', sans-serif"
                    }
                }
            },
            tooltip: {
                enabled: true,
                backgroundColor: 'rgba(0,0,0,0.8)',
                titleFont: { family: "'Inter', sans-serif", size: 14 },
                bodyFont: { family: "'Inter', sans-serif", size: 12 },
                callbacks: {
                    title: tooltipTitleCallback
                }
            }
        },
        scales: {
            y: {
                beginAtZero: true,
                ticks: {
                    color: brandColors.textColor,
                    font: { family: "'Inter', sans-serif" }
                },
                grid: {
                    color: brandColors.gridColor
                }
            },
            x: {
                ticks: {
                    color: brandColors.textColor,
                    font: { family: "'Inter', sans-serif" }
                },
                grid: {
                    display: false
                }
            }
        }
    };
    
    if (document.getElementById('slabComparisonChart')) {
        new Chart(document.getElementById('slabComparisonChart'), {
            type: 'bar',
            data: {
                labels: ['Up to 4L', '4L-8L', '8L-12L', '12L-16L', '16L-20L', '20L-24L', '>24L'],
                datasets: [{
                    label: 'New Regime Tax Rate (%)',
                    data: [0, 5, 10, 15, 20, 25, 30],
                    backgroundColor: brandColors.secondary,
                    borderColor: brandColors.secondary,
                    borderWidth: 1
                }, {
                    label: 'Old Regime Tax Rate (%)',
                    data: [5, 5, 20, 30, 30, 30, 30],
                    backgroundColor: brandColors.accent,
                    borderColor: brandColors.accent,
                    borderWidth: 1
                }]
            },
            options: { ...defaultChartOptions,
                scales: {
                    y: { ...defaultChartOptions.scales.y,
                        ticks: {
                            callback: function(value) { return value + '%' }
                        }
                    },
                    x: { ...defaultChartOptions.scales.x }
                }
            }
        });
    }

    if (document.getElementById('liabilityComparisonChart')) {
        new Chart(document.getElementById('liabilityComparisonChart'), {
            type: 'line',
            data: {
                labels: ['10L', '13L', '15L', '20L', '25L', '30L'],
                datasets: [
                    {
                        label: 'New Regime Tax (₹)',
                        data: [30000, 60000, 120000, 243750, 378750, 528750],
                        borderColor: brandColors.primary,
                        backgroundColor: 'rgba(0, 82, 212, 0.1)',
                        fill: true,
                        tension: 0.3
                    },
                    {
                        label: 'Old Regime Tax (with 3.5L Deduction) (₹)',
                        data: [42500, 82500, 142500, 282500, 427500, 577500],
                        borderColor: brandColors.accent,
                        backgroundColor: 'rgba(111, 177, 252, 0.1)',
                        fill: false,
                        tension: 0.3,
                        borderDash: [5, 5]
                    },
                     {
                        label: 'Old Regime Tax (with 5L Deduction) (₹)',
                        data: [12500, 42500, 112500, 262500, 412500, 562500],
                        borderColor: brandColors.light,
                        backgroundColor: 'rgba(178, 197, 255, 0.1)',
                        fill: false,
                        tension: 0.3,
                        borderDash: [10, 5]
                    }
                ]
            },
            options: { ...defaultChartOptions,
                plugins: { ...defaultChartOptions.plugins,
                    tooltip: { ...defaultChartOptions.plugins.tooltip,
                        callbacks: {
                            title: tooltipTitleCallback,
                            label: function(context) {
                                let label = context.dataset.label || '';
                                if (label) {
                                    label += ': ';
                                }
                                if (context.parsed.y !== null) {
                                    label += new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(context.parsed.y);
                                }
                                return label;
                            }
                        }
                    }
                 },
                 scales: {
                     y: { ...defaultChartOptions.scales.y,
                         ticks: {
                             callback: function(value) { return (value / 1000) + 'k' }
                         }
                     },
                     x: { ...defaultChartOptions.scales.x }
                 }
            }
        });
    }

    if (document.getElementById('revenueImpactChart')) {
        new Chart(document.getElementById('revenueImpactChart'), {
            type: 'bar',
            data: {
                labels: ['2019-20', '2020-21', '2021-22', '2022-23', '2023-24 (P)'],
                datasets: [{
                    label: 'Revenue Impact (₹ Crore)',
                    data: [155429, 128244, 168566, 196678, 220988],
                    backgroundColor: [brandColors.light, brandColors.accent, brandColors.secondary, brandColors.primary, '#003A9E'],
                    borderColor: '#fff',
                    borderWidth: 2
                }]
            },
            options: { ...defaultChartOptions,
                indexAxis: 'y',
                plugins: {
                     legend: { display: false },
                     tooltip: { ...defaultChartOptions.plugins.tooltip }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) { return (value / 1000) + 'k Cr' },
                            color: brandColors.textColor,
                            font: { family: "'Inter', sans-serif" }
                        },
                         grid: { color: brandColors.gridColor }
                    },
                    y: {
                        ticks: {
                            color: brandColors.textColor,
                            font: { family: "'Inter', sans-serif" }
                        },
                        grid: { display: false }
                    }
                }
            }
        });
    }
    
    if (document.getElementById('adoptionTrendChart')) {
        new Chart(document.getElementById('adoptionTrendChart'), {
            type: 'line',
            data: {
                labels: ['2020', '2021', '2023', '2024', '2025 (Est.)'],
                datasets: [{
                    label: 'Adoption Rate (%)',
                    data: [11, 18, 35, 45, 60],
                    borderColor: brandColors.primary,
                    backgroundColor: 'rgba(0, 82, 212, 0.2)',
                    fill: true,
                    tension: 0.4
                }]
            },
             options: { ...defaultChartOptions,
                scales: {
                    y: { ...defaultChartOptions.scales.y,
                        max: 100,
                        ticks: {
                            callback: function(value) { return value + '%' }
                        }
                    },
                    x: { ...defaultChartOptions.scales.x }
                }
             }
        });
    }

    if (document.getElementById('investmentImpactChart')) {
        new Chart(document.getElementById('investmentImpactChart'), {
            type: 'doughnut',
            data: {
                labels: ['Likely to shift from tax-saving products', 'Will continue with tax-saving products', 'Unsure/Neutral'],
                datasets: [{
                    label: 'Impact on Investment',
                    data: [45, 30, 25],
                    backgroundColor: [brandColors.primary, brandColors.accent, brandColors.light],
                    borderColor: '#ffffff',
                    borderWidth: 4,
                    hoverOffset: 10
                }]
            },
            options: { ...defaultChartOptions,
                cutout: '65%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: brandColors.textColor,
                            font: { family: "'Inter', sans-serif" },
                            boxWidth: 15,
                            padding: 20
                        }
                    },
                    tooltip: { ...defaultChartOptions.plugins.tooltip }
                },
                scales: {
                    y: { ...defaultChartOptions.scales.y, display: false },
                    x: { ...defaultChartOptions.scales.x, display: false }
                }
            }
        });
    }

    const getRecommendationBtn = document.getElementById('getRecommendationBtn');
    const annualIncomeInput = document.getElementById('annualIncome');
    const totalDeductionsInput = document.getElementById('totalDeductions');
    const recommendationResult = document.getElementById('recommendationResult');

    getRecommendationBtn.addEventListener('click', async () => {
        const annualIncome = annualIncomeInput.value;
        const totalDeductions = totalDeductionsInput.value;

        if (!annualIncome || !totalDeductions) {
            recommendationResult.textContent = 'Please enter both Annual Gross Income and Total Eligible Deductions.';
            return;
        }

        recommendationResult.textContent = 'Generating recommendation...';
        getRecommendationBtn.disabled = true;

        const prompt = `Considering an annual gross income of ₹${annualIncome} and total eligible deductions of ₹${totalDeductions} for a salaried individual in India, which tax regime (Old or New under Section 115BAC) would likely be more beneficial for FY 2025-26? Explain why in a concise manner, highlighting key factors. Do not provide professional financial advice, only a general recommendation. Start directly with the recommendation.`;

        let chatHistory = [];
        chatHistory.push({ role: "user", parts: [{ text: prompt }] });

        const payload = { contents: chatHistory };
        const apiKey = "";
        const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${apiKey}`;

        try {
            const response = await fetch(apiUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await response.json();

            if (result.candidates && result.candidates.length > 0 &&
                result.candidates[0].content && result.candidates[0].content.parts &&
                result.candidates[0].content.parts.length > 0) {
                const text = result.candidates[0].content.parts[0].text;
                recommendationResult.textContent = text;
            } else {
                recommendationResult.textContent = 'Could not generate a recommendation. Please try again.';
            }
        } catch (error) {
            console.error('Error calling Gemini API:', error);
            recommendationResult.textContent = 'An error occurred while fetching the recommendation. Please try again later.';
        } finally {
            getRecommendationBtn.disabled = false;
        }
    });

});
</script>

